{
  "name": "cli-merge",
  "version": "1.0.0",
  "description": "Merges 2 Planet Crafter save files into a single one, ready to be used in the game",
  "type": "module",
  "main": "cli/merge-cli.js",
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint:types": "tsc --noEmit",
    "merge": "bun --cwd ../.. packages/cli-merge/cli/merge-cli.js ",
    "merge:test": "bun test packages/cli-merge",
    "node:merge": "node cli/merge-cli.js --platform=node"
  }
}
