{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["@types/bun"],
    "maxNodeModuleJsDepth": 1
  },
  "include": ["packages/**/*.js"],
  "exclude": ["node_modules"]
}

