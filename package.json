{
  "name": "planet-crafter-save-tools",
  "version": "1.0.0",
  "description": "A set of tools to manipulate Planet Crafter save files",
  "workspaces": {
    "packages": ["packages/*"]
  },
  "type": "module",
  "main": "packages/cli-merge/cli/merge-cli.js",
  "scripts": {
    "clean": "rm -rf node_modules",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint:types": "tsc --noEmit",
    "dev:ui": "bun run --filter ui-save-manager dev",
    "preview:ui": "bun run --filter ui-save-manager preview",
    "clean:ui": "bun run --filter ui-save-manager clean",
    "merge": "bun run --filter cli-merge merge",
    "clean:merge": "rm -rf output",
    "test:merge": "bun test --filter cli-merge",
    "validate": "bun run --filter cli-validate validate",
    "test:validate": "bun test --filter cli-validate",
    "node:merge": "node packages/cli-merge/cli/merge-cli.js --platform=node",
    "node:validate": "node packages/cli-validate/cli/validate-cli.js --platform=node"
  },
  "catalogs": {
    "typescript": {
      "@types/bun": "^1.3.9",
      "typescript": "^5.9.3"
    },
    "testing": {
      "ajv": "^8.18.0"
    }
  },
  "devDependencies": {
    "@types/bun": "catalog:typescript",
    "typescript": "catalog:typescript",
    "ui-save-manager": "workspace:*"
  }
}
